{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    /**
     * Configurations for launching or attaching to a program.
     * 
     * The configurations are an array of objects, each with the following properties:
     * 
     * - `type`: the type of debugger to use (currently only "lldb" is supported)
     * - `request`: the request to make to the debugger (either "launch" or "attach")
     * - `name`: a human-readable name for the configuration
     * - `targetCreateCommands`: an array of commands to run when creating the target
     * - `processCreateCommands`: an array of commands to run when creating the process
     * - `pid`: the process ID to attach to (only used when `request` is "attach")
     * - `program`: the path to the program to launch (only used when `request` is "launch")
     * - `args`: an array of arguments to pass to the program when launching (only used when `request` is "launch")
     * - `cwd`: the current working directory to use when launching the program (only used when `request` is "launch")
     */
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Custom launch",
            "targetCreateCommands": [
                "target create ${workspaceFolder}/${command:pickFile}"
            ],
            "processCreateCommands": [
                "settings set target.run-args ${input:args}",
                "process launch"
            ]
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Custom launch",
            "targetCreateCommands": [
                "target create ${workspaceFolder}/<program>"
            ],
            "processCreateCommands": [
                "settings set target.run-args value1 value2 value3",
                "process launch"
            ]
        },
        {
            "type": "lldb",
            "request": "attach",
            "name": "Attach",
            "pid": "${command:pickMyProcess}" // use ${command:pickProcess} to pick other users' processes
        },
        {
            "name": "Launch",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceRoot}/<your program>",
            "args": [],
            "cwd": "${workspaceRoot}"
        },
        {
            "name": "Launch",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceRoot}/<your program>",
            "args": [],
            "cwd": "${workspaceRoot}"
        }
    ]
}