<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="Widget Settings"
        app:iconSpaceReserved="false">

        <SeekBarPreference
            android:key="default_transparency"
            android:title="Default Transparency"
            android:summary="Set the default transparency for the floating widget"
            android:defaultValue="20"
            android:max="100"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Security"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="pin_enabled"
            android:title="PIN Protection"
            android:summary="Require 4-digit PIN to open notes"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="About"
        app:iconSpaceReserved="false">

        <Preference
            android:key="about"
            android:title="About n0tez"
            android:summary="Version info and features"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="privacy_info"
            android:title="Privacy Information"
            android:summary="How your data is handled"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>
